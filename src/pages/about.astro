---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about Body Awareness Healing Arts Center and our licensed massage therapists in Caro, Michigan.">

  <section class="page-header">
    <div class="container">
      <h1>About Us</h1>
      <p>Getting to know your therapists</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-intro">
        <p>
          Body Awareness Healing Arts Center is a group of massage therapists that have been
          serving the Thumb area for a combined total of over 20 years. We welcome new clients
          and would love to help you on your wellness journey.
        </p>
      </div>

      <div class="team-grid">
        <div class="card team-card">
          <div class="team-avatar">JG</div>
          <h3>Jane Gemmell</h3>
          <p class="team-role">Licensed Massage Therapist & Owner</p>
          <p class="team-desc">
            As the founder and owner of Body Awareness, Jane brings years of expertise in
            therapeutic massage. She is skilled in Swedish, deep tissue, trigger point, and
            myofascial techniques, creating customized treatment plans for each client.
          </p>
        </div>
        <div class="card team-card">
          <div class="team-avatar">JW</div>
          <h3>Janet Wilson</h3>
          <p class="team-role">Licensed Massage Therapist — Lymphatic Specialist</p>
          <p class="team-desc">
            Janet specializes in lymphatic therapy, a gentle technique that supports the
            body's natural immune function and promotes overall wellness. She brings a
            compassionate, client-centered approach to every session.
          </p>
        </div>
      </div>

      <div class="about-cta">
        <h2>Ready to Get Started?</h2>
        <p>We'd love to welcome you. Give us a call to schedule your first appointment.</p>
        <a href="tel:9896730442" class="btn btn-primary">Call (989) 673-0442</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .about-intro {
    max-width: 700px;
    margin: 0 auto 3.5rem;
    text-align: center;
    font-size: 1.15rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .team-card {
    text-align: center;
    padding: 2.5rem 2rem;
  }

  .team-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: var(--color-white);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .team-card h3 {
    margin-bottom: 0.35rem;
  }

  .team-role {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .team-desc {
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .about-cta {
    text-align: center;
    margin-top: 4rem;
    padding: 3rem;
    background: var(--color-bg-warm);
    border-radius: var(--radius);
  }

  .about-cta h2 {
    margin-bottom: 0.75rem;
  }

  .about-cta p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
