---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Body Awareness Healing Arts Center in Caro, Michigan.">

  <section class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>We'd love to hear from you</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">

      <div class="contact-details">
        <div class="card contact-card">
          <div class="contact-icon">&#9742;</div>
          <h3>Phone</h3>
          <a href="tel:9896730442" class="contact-value">(989) 673-0442</a>
          <p class="contact-note">For questions, comments, or scheduling</p>
        </div>

        <div class="card contact-card">
          <div class="contact-icon">&#9906;</div>
          <h3>Location</h3>
          <p class="contact-value">1594 Pleasant View Drive<br>Caro, MI 48723</p>
        </div>

        <div class="card contact-card">
          <div class="contact-icon">&#9200;</div>
          <h3>Hours</h3>
          <p class="contact-value">Monday – Friday<br>9:00 AM – 5:00 PM</p>
          <p class="contact-note">By appointment only</p>
        </div>

        <div class="card contact-card">
          <div class="contact-icon">&#9733;</div>
          <h3>Follow Us</h3>
          <a
            href="https://facebook.com/carobodyawarenss"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value"
          >Find us on Facebook</a>
        </div>
      </div>

      <div class="map-container">
        <iframe
          title="Body Awareness Healing Arts Center Location"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2906.8!2d-83.3997!3d43.4911!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDI5JzI4LjAiTiA4M8KwMjMnNTguOSJX!5e0!3m2!1sen!2sus!4v1"
          width="100%"
          height="400"
          style="border:0; border-radius: var(--radius);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-layout {
    max-width: 900px;
    margin: 0 auto;
  }

  .contact-details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .contact-card {
    text-align: center;
    padding: 2rem;
  }

  .contact-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .contact-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.15rem;
  }

  .contact-value {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.6;
  }

  a.contact-value {
    color: var(--color-primary);
  }

  a.contact-value:hover {
    color: var(--color-primary-dark);
  }

  .contact-note {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .map-container {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  @media (max-width: 768px) {
    .contact-details {
      grid-template-columns: 1fr;
    }
  }
</style>
